               <label class="form-label">Availability *</label>
               <select id="p-availability" name="availability" 
 required>
                 <option value="in-stock">In Stock</option>
                 <option value="out-of-stock">Out of Stock</option>
               </select>
             </div>
           </div>

          <h3>Product Specifications</h3>
       
   
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Brand</label>
              <input type="text" id="p-Brand" name="Brand" placeholder="e.g., Nike" />
            </div>
            <div class="form-group">
             
 <label class="form-label">Model</label>
              <input type="text" id="p-Model" name="Model" placeholder="e.g., Gold Model" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Material</label>
              
<input type="text" id="p-chainstrap" name="chainStrap" placeholder="e.g., Mesh and synthetic" />
            </div>
            <div class="form-group">
              <label class="form-label">Case</label>
              <input type="text" id="p-case" name="case" placeholder="e.g., Rubber outsole" />
            </div>
          </div>

         
 <div class="form-row">
            <div class="form-group">
              <label class="form-label">Sole</label>
              <input type="text" id="p-caseback" name="caseBack" placeholder="e.g., Rubber outsole" />
            </div>
            <div class="form-group">
              <label class="form-label">Closure</label>
        
      <input type="text" id="p-Closure" name="Closure" placeholder="e.g., Lace-up" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Condition</label>
              <input type="text" id="p-Condition" name="Condition" placeholder="e.g., New / Like New" />
      
      </div>
            <div class="form-group">
              <label class="form-label">Size</label>
              <input type="text" id="p-size" name="size" placeholder="e.g., 24mm" />
            </div>
          </div>

          <div class="form-row">
            <div 
class="form-group">
              <label class="form-label">Weight</label>
              <input type="text" id="p-weight" name="weight" placeholder="e.g., 36 grams" />
            </div>
            <div class="form-group">
              <label class="form-label">Color</label>
              <input type="text" id="p-color" name="color" placeholder="e.g., Two Tone-Gold" />
   
         </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Style</label>
              <input type="text" id="p-Style" name="Style" placeholder="e.g., Low-top" />
            </div>
          
  <div class="form-group">
              <label class="form-label">Authenticity</label>
              <input type="text" id="p-Authenticity" name="Authenticity" placeholder="e.g., 12 Months Authenticity" />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Description</label>
            <textarea id="p-description" 
name="description" placeholder="Product description..."></textarea>
          </div>

          <div style="margin-top: 20px;">
            <button type="submit">Add Product</button>
            <button type="button" id="reset-form-btn" style="background: #6c757d;
margin-left: 8px;">Reset</button>
          </div>
        </form>
      </div>
    </div>

    <div id="edit-modal" class="modal">
      <div class="modal-content">
        <div class="modal-header">
          <h2>Edit Product</h2>
          <button class="close-modal" id="close-edit-modal">Close</button>
        </div>
        <form id="edit-product-form" 
enctype="multipart/form-data">
          <input type="hidden" id="edit-id" name="id" />
           <div class="form-group">
             <label class="form-label">Product Name *</label>
             <input type="text" id="edit-name" name="name" required />
           </div>

           <div class="form-group">
             <label class="form-label">On Sale</label>
               <div class="checkbox-group">
                 <input type="checkbox" id="edit-onsale" name="onSale" />
                
  <span>Mark as on sale</span>
               </div>
           </div>

           <div class="form-row">
             <div class="form-group">
          
      <label class="form-label">Regular Price (PKR) *</label>
               <input type="number" id="edit-price" name="price" step="0.01" required />
             </div>
             <div class="form-group" id="edit-oldprice-group" style="display: none;">
               <label class="form-label">Sale Price (PKR)</label>
               <input type="number" id="edit-oldprice" name="oldPrice" step="0.01" />
             </div>
           </div>

           <div class="form-group">
             <label class="form-label">Product Image (leave empty to keep current)</label>
             <input type="file" id="edit-image" name="image" accept="image/*" />
             <img id="edit-image-preview" class="image-preview" style="display: none;" />
             <div id="edit-current-image" style="margin-top: 8px;"></div>
          
  </div>

           <div class="form-row">
             <div class="form-group">
               <label class="form-label">Availability *</label>
               <select id="edit-availability" name="availability" required>
                 <option value="in-stock">In Stock</option>
                 <option value="out-of-stock">Out of Stock</option>
      
          </select>
             </div>
           </div>

          <h3>Product Specifications</h3>
          
          <div class="form-row">
            <div class="form-group">
              <label 
class="form-label">Brand</label>
              <input type="text" id="edit-Brand" name="Brand" />
            </div>
            <div class="form-group">
              <label class="form-label">Model</label>
              <input type="text" id="edit-Model" name="Model" />
            </div>
          </div>

  
        <div class="form-row">
            <div class="form-group">
              <label class="form-label">Material</label>
              <input type="text" id="edit-chainstrap" name="chainStrap" />
            </div>
            <div class="form-group">
              <label class="form-label">Case</label>
   
           <input type="text" id="edit-case" name="case" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Sole</label>
              <input type="text" id="edit-caseback" name="caseBack" />
     
       </div>
            <div class="form-group">
              <label class="form-label">Closure</label>
              <input type="text" id="edit-Closure" name="Closure" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
 
             <label class="form-label">Condition</label>
              <input type="text" id="edit-Condition" name="Condition" />
            </div>
            <div class="form-group">
              <label class="form-label">Size</label>
              <input type="text" id="edit-size" name="size" />
          
  </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Weight</label>
              <input type="text" id="edit-weight" name="weight" />
            </div>
            <div class="form-group">
      
        <label class="form-label">Color</label>
              <input type="text" id="edit-color" name="color" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Style</label>
            
  <input type="text" id="edit-Style" name="Style" />
            </div>
            <div class="form-group">
              <label class="form-label">Authenticity</label>
              <input type="text" id="edit-Authenticity" name="Authenticity" />
            </div>
          </div>

          <div class="form-group">
   
         <label class="form-label">Description</label>
            <textarea id="edit-description" name="description"></textarea>
          </div>

          <div style="margin-top: 20px;">
            <button type="submit">Update Product</button>
            <button type="button" id="cancel-edit-btn" style="background: #6c757d;
margin-left: 8px;">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    <div class="card" style="margin-top:24px;">
      <h2>Products (<%= products.length %>)</h2>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Price</th>
        
    <th>Sale Price</th>
            <th>Availability</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="products-body">
          <% products.forEach(p => { %>
            <tr>
              <td><%= p.name %></td>
  
            <td>Rs.<%= p.price ? p.price.toLocaleString() : '0' %> PKR</td>
              <td><%= p.oldPrice ? 'Rs.' + p.oldPrice.toLocaleString() + ' PKR' : '-' %></td>
            <td><%= p.availability === 'in-stock' ? 'In Stock' : 'Out of Stock' %></td>
            <td>
              <div class="btn-group">
      
          <button class="edit" data-product-id="<%= p._id %>" data-action="edit">Edit</button>
                <button class="danger" data-product-id="<%= p._id %>" data-action="delete">Delete</button>
              </div>
            </td>
            </tr>
          <% }) %>
        </tbody>
      
</table>
    </div>

    <script>
      // Toggle sale price field based on "On Sale" checkbox (Add Product Form)
      function toggleSalePriceField() {
        const onSaleCheckbox = document.getElementById('p-onsale');
        const salePriceGroup = document.getElementById('p-oldprice-group');
        
        if (onSaleCheckbox && salePriceGroup) {
          if (onSaleCheckbox.checked) {
            salePriceGroup.style.display = 'block';
          } else {
            salePriceGroup.style.display = 'none';
            // Clear the value when hidden
            document.getElementById('p-oldprice').value = '';
          }
        }
      }
      
      // Toggle sale price field based on "On Sale" checkbox (Edit Product Form)
      function toggleEditSalePriceField() {
        const onSaleCheckbox = document.getElementById('edit-onsale');
        const salePriceGroup = document.getElementById('edit-oldprice-group');
        
        if (onSaleCheckbox && salePriceGroup) {
          if (onSaleCheckbox.checked) {
            salePriceGroup.style.display = 'block';
          } else {
            salePriceGroup.style.display = 'none';
            // Clear the value when hidden
            document.getElementById('edit-oldprice').value = '';
          }
        }
      }
      
      // Add event listeners for "On Sale" checkboxes
      document.addEventListener('DOMContentLoaded', function() {
        // Add Product Form
        const addOnSaleCheckbox = document.getElementById('p-onsale');
        if (addOnSaleCheckbox) {
          addOnSaleCheckbox.addEventListener('change', toggleSalePriceField);
        }
        
        // Edit Product Form
        const editOnSaleCheckbox = document.getElementById('edit-onsale');
        if (editOnSaleCheckbox) {
          editOnSaleCheckbox.addEventListener('change', toggleEditSalePriceField);
        }
      });
      
      // Image preview
      document.getElementById('p-image').addEventListener('change', function(e) {
        const file = e.target.files[0]
        if (file) {
          const reader = new FileReader()
          reader.onload = function(e) {
            const preview = document.getElementById('image-preview')
            preview.src 
= e.target.result
            preview.style.display = 'block'
          }
          reader.readAsDataURL(file)
        }
      })

      // Product form submission
      document.getElementById('product-form').addEventListener('submit', async function(e) {
        e.preventDefault()
        const formData = new FormData(this)
        const submitBtn = this.querySelector('button[type="submit"]')
  
      const originalText = submitBtn.textContent
        
        // Disable button and show loading
        submitBtn.disabled = true
        submitBtn.textContent = 'Adding...'
        
        try {
          const res = await fetch('/api/products', {
            method: 'POST',
     
       body: formData
          })
          
          // --- FIX START: Read as text first, then parse ---
          const responseText = await res.text();
          let data;
          try {
            data = JSON.parse(responseText);
          } catch (parseErr) {
            // Not JSON, use the raw text for error
          }
          // --- FIX END ---
          
          if (res.ok) {
            alert('Product added successfully!')
            // Reset form
            this.reset()
            document.getElementById('image-preview').style.display = 'none'
 
           // Reload page to show new product
            setTimeout(() => location.reload(), 500)
          } else {
            // Use parsed message if available, otherwise use raw text
            const errorMessage = (data && data.message) ? data.message : responseText;
            alert('Failed to add product: ' + (errorMessage ||
'Unknown error'))
            submitBtn.disabled = false
            submitBtn.textContent = originalText
          }
        } catch (err) {
          console.error('Product creation error:', err)
          alert('Error: ' + err.message)
          submitBtn.disabled = false
          submitBtn.textContent = 
originalText
        }
      })

      function resetForm() {
        document.getElementById('product-form').reset()
        document.getElementById('image-preview').style.display = 'none'
      }

      // Reset form button
      document.getElementById('reset-form-btn').addEventListener('click', resetForm)

      async function editProduct(id) {
        try {
          const res = await fetch('/api/products/' + id)
    
      const data = await res.json()
          if (!res.ok) {
            alert('Failed to load product: ' + (data.message || 'Unknown error'))
            return
          }
          
          const product = data.data
          
  
        // Populate edit form
          document.getElementById('edit-id').value = product._id
          document.getElementById('edit-name').value = product.name ||
''
          document.getElementById('edit-price').value = product.price ||
''
          document.getElementById('edit-oldprice').value = product.oldPrice ||
''
          document.getElementById('edit-availability').value = product.availability ||
'in-stock'
          document.getElementById('edit-onsale').checked = product.onSale ||
false
          
          // Show/hide sale price field based on onSale status
          toggleEditSalePriceField()
          document.getElementById('edit-Brand').value = product.Brand ||
''
          document.getElementById('edit-Model').value = product.Model ||
''
          document.getElementById('edit-chainstrap').value = product.chainStrap ||
''
          document.getElementById('edit-case').value = product.case ||
''
          document.getElementById('edit-caseback').value = product.caseBack ||
''
          document.getElementById('edit-Closure').value = product.Closure ||
''
          document.getElementById('edit-Condition').value = product.Condition ||
''
          document.getElementById('edit-size').value = product.size ||
''
          document.getElementById('edit-weight').value = product.weight ||
''
          document.getElementById('edit-color').value = product.color ||
''
          document.getElementById('edit-Style').value = product.Style ||
''
          document.getElementById('edit-Authenticity').value = product.Authenticity ||
''
          document.getElementById('edit-description').value = product.description ||
''
          
          // Show current image
          const currentImageDiv = document.getElementById('edit-current-image')
          if (product.image) {
            currentImageDiv.innerHTML = `<p><strong>Current Image:</strong></p><img src="${product.image}" class="image-preview" style="display: block;"
/>`
          } else {
            currentImageDiv.innerHTML = ''
          }
          
          // Reset image preview
          document.getElementById('edit-image-preview').style.display = 'none'
          document.getElementById('edit-image').value = ''
          
       
   // Show modal
          document.getElementById('edit-modal').style.display = 'block'
        } catch (err) {
          console.error('Edit product error:', err)
          alert('Error loading product: ' + err.message)
        }
      }

      function closeEditModal() {
        document.getElementById('edit-modal').style.display = 'none'
        document.getElementById('edit-product-form').reset()
    
  }

      // Edit image preview
      document.getElementById('edit-image').addEventListener('change', function(e) {
        const file = e.target.files[0]
        if (file) {
          const reader = new FileReader()
          reader.onload = function(e) {
            const preview = document.getElementById('edit-image-preview')
            preview.src = e.target.result
    
        preview.style.display = 'block'
            document.getElementById('edit-current-image').innerHTML = '<p><em>New image selected</em></p>'
          }
          reader.readAsDataURL(file)
        }
      })

      // Edit form submission
      document.getElementById('edit-product-form').addEventListener('submit', async function(e) {
        e.preventDefault()
        const formData = new FormData(this)
  
      const productId = document.getElementById('edit-id').value
        const submitBtn = this.querySelector('button[type="submit"]')
        const originalText = submitBtn.textContent
        
        submitBtn.disabled = true
        submitBtn.textContent = 'Updating...'
        
        try {
          const res = await fetch('/api/products/' + productId, {
       
     method: 'PUT',
            body: formData
          })
          
          // --- FIX START: Read as text first, then parse ---
          const responseText = await res.text();
          let data;
          try {
            data = JSON.parse(responseText);
          } catch (parseErr) {
            // Not JSON, use the raw text for error
          }
          // --- FIX END ---
          
          if (res.ok) {
            alert('Product updated successfully!')
            closeEditModal()
            setTimeout(() => location.reload(), 500)
   
       } else {
            // Use parsed message if available, otherwise use raw text
            const errorMessage = (data && data.message) ? data.message : responseText;
            alert('Failed to update product: ' + (errorMessage ||
'Unknown error'))
            submitBtn.disabled = false
            submitBtn.textContent = originalText
          }
        } catch (err) {
          console.error('Update product error:', err)
          alert('Error: ' + err.message)
          submitBtn.disabled = false
          submitBtn.textContent = 
originalText
        }
      })

      // Close modal when clicking outside
      document.getElementById('edit-modal').addEventListener('click', function(e) {
        if (e.target === this) {
          closeEditModal()
        }
      })

      // Close modal buttons
      document.getElementById('close-edit-modal').addEventListener('click', closeEditModal)
      document.getElementById('cancel-edit-btn').addEventListener('click', closeEditModal)

      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn')
      const sidebar = document.querySelector('.sidebar')
      if (mobileMenuBtn) {
        mobileMenuBtn.addEventListener('click', function() {
          sidebar.classList.toggle('open')
        })
      }

      // Edit and Delete button handlers (using event delegation)
      document.addEventListener('click', function(e) {
        if (e.target.dataset.action === 'edit') {
     
     editProduct(e.target.dataset.productId)
        } else if (e.target.dataset.action === 'delete') {
          deleteProduct(e.target.dataset.productId)
        }
      })

      async function deleteProduct(id) {
        if (!confirm('Delete this product?')) return
        try {
          const res = await fetch('/api/products/' + id, { method: 'DELETE' })
       
   if (res.ok) {
            alert('Product deleted successfully!')
            location.reload()
          } else {
            const data = await res.json()
            alert('Failed to delete product: ' + (data.message ||
'Unknown error'))
          }
        } catch (err) {
          alert('Error: ' + err.message)
        }
      }

    </script>
  </body>
</html>
