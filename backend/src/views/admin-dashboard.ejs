       <input type="text" id="p-name" name="name" placeholder="e.g., Chanel (Two Tone-Gold)" required />
           </div>

           <div class="form-group">
             <label class="form-label">On Sale</label>
         
       <div class="checkbox-group">
                 <input type="checkbox" id="p-onsale" name="onSale" />
                 <span>Mark as on sale</span>
               </div>
           </div>

           <div class="form-row">
             <div class="form-group">
               <label class="form-label">Regular Price (PKR) *</label>
               <input type="number" id="p-price" name="price" placeholder="7499" step="0.01" required />
             
 </div>
             <div class="form-group" id="p-oldprice-group" style="display: none;">
               <label class="form-label">Sale Price (PKR)</label>
               <input type="number" id="p-oldprice" name="oldPrice" placeholder="6499" step="0.01" />
             </div>
           </div>

           <div class="form-group">
             <label class="form-label">Product Image *</label>
   
